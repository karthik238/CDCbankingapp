from pyspark.sql import SparkSession
from pyspark.sql.functions import avg

# Create Spark Session
spark = SparkSession.builder \
    .appName("WeatherAnalysis") \
    .getOrCreate()

# Read CSV file
df = spark.read.csv(
    "weather.csv",
    header=True,
    inferSchema=True
)

# Show dataset
df.show()

# Average temperature per year
df.groupBy("year") \
  .agg(avg("temperature")) \
  .show()
